        "YARN_ENABLE_IMMUTABLE_INSTALLS": "false",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "node": "20.19.4"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "e.cikan@icloud.com",
        "ascAppId": "6782220073",
        "appleTeamId": "K74FJVM4T6"
      }
    }
