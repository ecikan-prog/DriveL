{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "dist",
    "rootDir": ".",

    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true
  },
  "include": [
    "server",
    "routers",
    "portal",
    "admin",
    "export-routes"
  ]
}