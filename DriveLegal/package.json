{
  "name": "drivelegal-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "esbuild server/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=esm --packages=external",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.9.16",
    "dotenv": "^16.4.7",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "superjson": "^2.2.2"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "esbuild": "^0.24.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17"
  }
}
