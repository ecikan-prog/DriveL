{
  "name": "app-template",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "type": "commonjs",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "esbuild server/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
  "@trpc/client": "^10.45.2",
  "@trpc/react-query": "^10.45.2",
  "@trpc/server": "^10.45.2",

  "babel-preset-expo": "~54.0.0",
  "cors": "^2.8.5",
  "dotenv": "^16.6.1",
  "drizzle-orm": "^0.30.10",

  "expo": "~54.0.0",
  "expo-router": "~6.0.0",

  "express": "^4.19.2",
  "mysql2": "^3.11.0",

  "nativewind": "^4.1.23",

  "react": "19.1.0",
  "react-native": "0.81.4",
  "react-native-worklets": "^0.5.1",

  "superjson": "^2.2.1",
  "xlsx-populate": "^1.21.0",
  "zod": "^3.23.8"
},
   "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "drizzle-kit": "^0.21.4",
    "esbuild": "^0.23.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5",
    "eslint": "^9.8.0",
    "prettier": "^3.3.3"
  }
}
