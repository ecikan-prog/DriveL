{
  "name": "app-template",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "type": "commonjs",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "esbuild server/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "mobile:doctor": "expo-doctor",
    "mobile:bundle:ios": "expo export --platform ios --clear --output-dir dist-ios-test",
    "mobile:prebuild:ios": "expo prebuild --platform ios --clean"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",

    "babel-preset-expo": "~54.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.30.10",

    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.9",
    "expo-keep-awake": "~15.0.7",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-video": "~3.0.16",

    "express": "^4.19.2",
    "mysql2": "^3.11.0",
    "nativewind": "4.1.23",

    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.6",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",

    "superjson": "^2.2.1",
    "xlsx-populate": "^1.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "drizzle-kit": "^0.21.4",
    "esbuild": "^0.23.1",
    "eslint": "^9.8.0",
    "expo-doctor": "^1.20.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
